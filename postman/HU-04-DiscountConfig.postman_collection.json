{
  "info": {
    "_postman_id": "hu-04-discount-config",
    "name": "HU-04: Configuración de Descuentos",
    "description": "Test cases para endpoints de configuración de descuentos (CRITERIO-4.1 al 4.5)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "CRITERIO-4.1: Crear configuración de descuentos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 Created', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response tiene DiscountConfigResponse', function() {",
              "  const data = pm.response.json();",
              "  pm.expect(data).to.have.property('uid');",
              "  pm.expect(data).to.have.property('ecommerceId');",
              "  pm.expect(data).to.have.property('maxDiscountLimit');",
              "  pm.expect(data).to.have.property('currencyCode');",
              "  pm.expect(data).to.have.property('isActive', true);",
              "});",
              "",
              "// Guardar uid para siguientes requests",
              "const data = pm.response.json();",
              "pm.globals.set('discount_config_id', data.uid);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{ACCESS_TOKEN}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ecommerceId\": \"{{ECOMMERCE_ID}}\",\n  \"maxDiscountLimit\": \"150.00\",\n  \"currencyCode\": \"USD\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/discount-config",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "v1",
            "discount-config"
          ]
        }
      }
    },
    {
      "name": "CRITERIO-4.2: Obtener configuración activa",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contiene configuración activa', function() {",
              "  const data = pm.response.json();",
              "  pm.expect(data).to.have.property('uid');",
              "  pm.expect(data).to.have.property('ecommerceId');",
              "  pm.expect(data).to.have.property('maxDiscountLimit');",
              "  pm.expect(data.isActive).to.equal(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{ACCESS_TOKEN}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/discount-config?ecommerceId={{ECOMMERCE_ID}}",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "v1",
            "discount-config"
          ],
          "query": [
            {
              "key": "ecommerceId",
              "value": "{{ECOMMERCE_ID}}"
            }
          ]
        }
      }
    },
    {
      "name": "CRITERIO-4.3: Crear prioridades de descuentos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 Created', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response contiene prioridades ordenadas', function() {",
              "  const data = pm.response.json();",
              "  pm.expect(data).to.have.property('configId');",
              "  pm.expect(data).to.have.property('priorities');",
              "  pm.expect(data.priorities).to.be.an('array');",
              "  pm.expect(data.priorities.length).to.be.greaterThan(0);",
              "});",
              "",
              "// Verificar que las prioridades están ordenadas",
              "const data = pm.response.json();",
              "for (let i = 0; i < data.priorities.length; i++) {",
              "  pm.expect(data.priorities[i].priorityLevel).to.equal(i + 1);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{ACCESS_TOKEN}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"configId\": \"{{discount_config_id}}\",\n  \"discountTypePriorities\": [\n    {\n      \"discountTypeId\": \"{{FIDELITY_TYPE_ID}}\",\n      \"priorityLevel\": 1\n    },\n    {\n      \"discountTypeId\": \"{{SEASONAL_TYPE_ID}}\",\n      \"priorityLevel\": 2\n    },\n    {\n      \"discountTypeId\": \"{{PROMOTIONAL_TYPE_ID}}\",\n      \"priorityLevel\": 3\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/discount-priority",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "v1",
            "discount-priority"
          ]
        }
      }
    },
    {
      "name": "CRITERIO-4.4: Obtener prioridades configuradas",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contiene prioridades ordenadas', function() {",
              "  const data = pm.response.json();",
              "  pm.expect(data).to.have.property('priorities');",
              "  pm.expect(Array.isArray(data.priorities)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{ACCESS_TOKEN}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/discount-priority?configId={{discount_config_id}}",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "v1",
            "discount-priority"
          ],
          "query": [
            {
              "key": "configId",
              "value": "{{discount_config_id}}"
            }
          ]
        }
      }
    },
    {
      "name": "CRITERIO-4.5: Validar maxDiscountLimit > 0 (Error Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 Bad Request', function() {",
              "  pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Error message indica validación de maxDiscountLimit', function() {",
              "  const error = pm.response.json();",
              "  pm.expect(error.message || error.error).to.include('maxDiscountLimit');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{ACCESS_TOKEN}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ecommerceId\": \"{{ECOMMERCE_ID}}\",\n  \"maxDiscountLimit\": \"-50.00\",\n  \"currencyCode\": \"USD\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/discount-config",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "v1",
            "discount-config"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "ACCESS_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "ECOMMERCE_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "FIDELITY_TYPE_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "SEASONAL_TYPE_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "PROMOTIONAL_TYPE_ID",
      "value": "",
      "type": "string"
    }
  ]
}
