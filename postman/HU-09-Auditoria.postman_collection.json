    {
      "name": "CRITERIO-9.4: PUT audit log retorna 405 (inmutable)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 405 Method Not Allowed', function() {",
              "  pm.response.to.have.status(405);",
              "});",
              "",
              "pm.test('Mensaje indica operación no permitida', function() {",
              "  const errorResponse = pm.response.json();",
              "  pm.expect(errorResponse.message || errorResponse.error).to.include('405');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{ACCESS_TOKEN}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{ \"action\": \"updated\" }"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/audit-logs/{{AUDIT_LOG_ID}}",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
            "v1",
            "audit-logs",
            "{{AUDIT_LOG_ID}}"
          ]
        }
